# Copy to .env and adjust. Only FRIGATE_URL is required.
FRIGATE_URL=http://frigate:5000

# Web server
# HOST=0.0.0.0
# PORT=8975

# frigate-ext: inject a "Better Face Recognition" button into Frigate's /faces
# page, via Frigate's own nginx (needs /var/run/docker.sock mounted + this
# container on Frigate's network). See the README "Faces-page button" section.
# NGINX_AUTOCONFIG=true                       # false disables the injected button
# FRIGATE_CONTAINER=frigate                   # Frigate's docker container name
# BFR_UPSTREAM=better-face-recognition:8975   # THIS container_name:port (nginx upstream)
# BFR_PUBLIC_URL=                             # override the button's target URL wholesale
# BFR_PUBLIC_PORT=8975                        # else the button opens http://<host>:<this>/
# BFR_FRIGATE_UI_URL=                         # "back to Frigate" button (default https://<host>:8971/)

# Model + pipeline
# MODEL_NAME=buffalo_l        # InsightFace pack: SCRFD detector + ArcFace recogniser
# FIQA_VARIANT=l              # eDifFIQA quality model: t/s/m/l (l = best, t = 7 MB tiny)
# POLL_INTERVAL=10            # seconds between Frigate train-folder polls
# MODEL_IDLE_TTL=180          # release the face models after this idle (s) to free RAM (~0.8 GB)
# UI_ACTIVE_WINDOW=30         # keep ingesting new crops this long after the Review tab last polled
# THUMB_SIZE=320              # stored thumbnail max edge (px)
# FRIGATE_WRITEBACK=true      # train/delete in Frigate on your actions
# FRIGATE_VERIFY_TLS=false
# AUTH=frigate                # "frigate" = require login via Frigate's users; "none" = open
# DET_THRESHOLD=0.5           # SCRFD sensitivity; lower catches more blurry/borderline faces (+ more junk)
# BLUR_THRESHOLD=0            # auto-discard faces below this eDifFIQA quality score 0-100 (0 = off; tune in the UI)

# Tunables (seeded into the DB on first run, then managed from the UI)
# MATCH_THRESHOLD=0.5
# REJECT_THRESHOLD=0.5
# AUTO_REJECT=true
# AUTO_LABEL=false
